#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

python3 -m pip install --requirement requirements.txt

# Install GitHub CLI (gh)
if ! command -v gh &> /dev/null; then
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | sudo dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | sudo tee /etc/apt/sources.list.d/github-cli.list > /dev/null
    sudo apt-get update -q && sudo apt-get install -y gh
fi

# Install Claude Code CLI (native installer, non-interactive)
if ! command -v claude &> /dev/null; then
    curl -fsSL https://claude.ai/install.sh | bash
fi

# Register Playwright MCP server for browser automation
if command -v claude &> /dev/null; then
    claude mcp add playwright -- npx -y @playwright/mcp@latest --headless --no-sandbox --caps vision 2>/dev/null || true
    npx --yes playwright install chrome 2>/dev/null || true
fi
