#!/usr/bin/env bash

set -e

cd "$(dirname "$0")/.."

# Fix volume ownership (Docker named volumes are created owned by root)
sudo chown -R vscode:vscode /home/vscode 2>/dev/null || true

python3 -m pip install --requirement requirements.txt

# Register Playwright MCP server for browser automation
if command -v claude &> /dev/null; then
    claude mcp add playwright -- npx -y @playwright/mcp@latest --headless --no-sandbox --caps vision 2>/dev/null || true
fi
