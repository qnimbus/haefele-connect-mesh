# Playwright test artifacts
.playwright-mcp/

# Claude Code persistence (.claude-home/ is tracked selectively)
# Track: .claude.json (MCP servers, project settings), projects/ (memory), plugins/
# Ignore: credentials, history, cache, and all ephemeral runtime data
.claude-home/.claude/.credentials.json
.claude-home/.claude/history.jsonl
.claude-home/.claude/cache/
.claude-home/.claude/backups/
.claude-home/.claude/debug/
.claude-home/.claude/downloads/
.claude-home/.claude/telemetry/
.claude-home/.claude/shell-snapshots/
.claude-home/.claude/file-history/
.claude-home/.claude/session-env/
.claude-home/.claude/ide/
.claude-home/.claude/plans/
.claude-home/.claude/mcp-needs-auth-cache.json

